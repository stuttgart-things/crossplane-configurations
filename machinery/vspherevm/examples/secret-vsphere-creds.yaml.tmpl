---
# Hand-created vSphere credentials Secret (no ESO/Vault path).
# Referenced by the ClusterProviderConfig (examples/clusterproviderconfig.yaml):
#   secretRef: {name: vsphere-creds, namespace: crossplane-system, key: credentials}
#
# ⚠️ The JSON key MUST be `user` (NOT `username`) — the provider reads creds["user"];
#    a wrong key yields a misleading "incorrect user name or password" from vCenter.
# ⚠️ `server` = bare vCenter host, no https:// and no /sdk.
# ⚠️ `allow_unverified_ssl` is a STRING ("true"), not a bool.
#
# This is a .tmpl on purpose: fill the placeholders, then apply the edited copy.
# Do NOT commit real credentials.
#
#   sed 's/<VSPHERE_USER>/.../; s/<VSPHERE_PASSWORD>/.../; s/<VSPHERE_SERVER>/.../' \
#     examples/secret-vsphere-creds.yaml.tmpl | kubectl apply -f -
apiVersion: v1
kind: Secret
metadata:
  name: vsphere-creds
  namespace: crossplane-system
type: Opaque
stringData:
  # single JSON blob under the `credentials` key (matches the ProviderConfig secretRef.key)
  credentials: |
    {"user":"<VSPHERE_USER>","password":"<VSPHERE_PASSWORD>","server":"<VSPHERE_SERVER>","allow_unverified_ssl":"true"}
